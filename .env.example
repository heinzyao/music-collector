SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
PLAYLIST_NAME=Daily Music Picks

# LINE Messaging API（選用，未設定則不發送通知）
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_USER_ID=

# Telegram Bot API（選用，未設定則不發送通知）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack Incoming Webhook（選用，未設定則不發送通知）
SLACK_WEBHOOK_URL=

# Playwright 瀏覽器渲染（選用，用於 JS 重度渲染網站）
ENABLE_PLAYWRIGHT=false

# 來源健康檢查閾值（選用，未設定則使用預設值）
# SOURCE_FAILURE_THRESHOLD=3        # 連續失敗幾次標記為 unhealthy
# SOURCE_EMPTY_DAYS_THRESHOLD=5     # 連續幾天無曲目標記為 warning
